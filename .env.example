# ─── LexVerify CRAG Environment Variables ───
# Copy this file to .env and fill in your API keys

# OpenAI — used for embeddings (text-embedding-3-small) and generation (GPT-4o)
OPENAI_API_KEY=sk-your-openai-key-here

# Tavily — used for web search fallback when CRAG evaluator triggers augmentation
TAVILY_API_KEY=tvly-your-tavily-key-here

# Pinecone — vector store for legal document embeddings
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=lexverify-legal

# ─── Optional Overrides ───
# EMBEDDING_MODEL=text-embedding-3-small
# GENERATOR_MODEL=gpt-4o
# EVALUATOR_MODEL=gpt-4o
# TOP_K=10
# CONFIDENCE_THRESHOLD_HIGH=0.8
# CONFIDENCE_THRESHOLD_LOW=0.4
